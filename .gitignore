# Runtime state
.aid/
!.aid/.gitkeep

# Container artifacts
.aid/aidhs.sif
.aid/aidhs.sif.*
.aid/cache/
.aid/tmp/

# Generated compose (regenerated on install)
compose.yml

# Logs (may contain host paths)
logs/*
!logs/.gitkeep

# Pipeline outputs (keep structure via .gitkeep)
output/*
!output/.gitkeep

# User data (never commit PHI or MRI)
input/*
!input/.gitkeep
!input/README.md
!input/bids_config.json.example
!input/dataset_description.json.example

# License and local config (never commit)
aidhs_license.txt
jobs/cidur/config.env
jobs/urmc_test/config.env
jobs/urmc_test/demographics_file.csv
jobs/urmc_test/subjects_list.txt
*.env.local

# Demographics with real subject IDs / ages / sex (use *.example templates)
demographics_file.csv
jobs/cidur/demographics_file.csv
jobs/cidur/subjects_list.txt

# Snakemake workflow local config and runtime
aidhs_py/config/subjects.tsv
aidhs_py/config/controls.tsv
aidhs_py/config/demographics_file.csv
aidhs_py/config/cohorts/*.yaml
!aidhs_py/config/cohorts/*.yaml.example
aidhs_py/.flags/
aidhs_py/.snakemake/
aidhs_py/logs/*
!aidhs_py/logs/.gitkeep
aidhs_py/report.html
aidhs_py/dag.svg

# OS / editor
.DS_Store
*.swp
*~

# Copy to config.env and edit for your site (config.env is gitignored).
# Source before submit:  source jobs/cidur/config.env

# Absolute path to external BIDS dataset (for input/ symlinks)
export CIDUR_BIDS="/path/to/your/BIDS/data_bids"

# Space-separated subject IDs to run (override in submit.sh or here)
export AIDHS_SUBJECTS="sub-example001"

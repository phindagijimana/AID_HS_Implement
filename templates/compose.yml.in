# Generated by ./aid install — do not edit paths by hand; re-run install after moving the pipeline.
services:
  aidhs:
    image: meldproject/aidhs:latest
    platform: "linux/amd64"
    volumes:
      - __AID_DATA_DIR__:/data
    environment:
      - AIDHS_LICENSE=/run/secrets/aidhs_license.txt
    secrets:
      - aidhs_license.txt
    user: ${DOCKER_USER:-0:0}
__GPU_BLOCK__

secrets:
  aidhs_license.txt:
    file: __AID_LICENSE_FILE__
